PORT=8080

# Required: 32-byte hex key. Generate via: openssl rand -hex 32
PHONEBOT_ENCRYPTION_KEY=replace-me-with-openssl-rand-hex-32

# Storage location for sqlite db, projects, claude-home, traefik certs (host path)
PHONEBOT_DATA_DIR=./data

# Sandbox container name spawn'd by api via `docker exec`
PHONEBOT_SANDBOX_CONTAINER=phonebot-agent

# Workdir prefix INSIDE the sandbox where projects are mounted
PHONEBOT_SANDBOX_WORKDIR_BASE=/workspace

# UID used for the non-root sandbox user. start.sh sets this to `id -u`
# so the agent can write host bind-mounted project files on Docker Desktop.
PHONEBOT_AGENT_UID=1000

# Domain for project preview. local profile uses *.localhost (no DNS needed in browsers)
PHONEBOT_BASE_DOMAIN=localhost

# local | production. local => http via traefik *.localhost; production => https + ACME
PHONEBOT_PROFILE=local

# Concurrency cap on simultaneous agent runs
PHONEBOT_MAX_CONCURRENT_RUNS=2

# ACME (only used when PHONEBOT_PROFILE=production)
ACME_EMAIL=admin@example.com
