{
  "name": "phonebot",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS orchestration service driving claude-code in a Docker sandbox for full-stack AI coding.",
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.js",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:e2e": "RUN_E2E=1 jest --runInBand --testPathPattern=test/e2e",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "better-sqlite3": "^11.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dockerode": "^4.0.2",
    "fast-glob": "^3.3.2",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "rxjs": "^7.8.1",
    "simple-git": "^3.27.0",
    "uuid": "^11.0.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/dockerode": "^3.3.32",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0"
  }
}
